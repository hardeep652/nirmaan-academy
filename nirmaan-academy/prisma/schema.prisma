generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model StudentData {
  id              Int     @id @default(autoincrement())
  studentName     String
  imageUrl        String
  course          String
  rank            Int
  marks           Float?
  collegeName     String?
  branchName      String?
  admissionYear   Int
  achievementYear Int?
  testimonial     String?
  featured        Boolean
  displayOrder    Int
}
